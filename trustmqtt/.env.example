# Postgres
POSTGRES_DB=trustmqtt
POSTGRES_USER=trustmqtt
POSTGRES_PASSWORD=trustmqtt

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Database (SQLAlchemy URL, must match POSTGRES_* above)
DATABASE_URL=postgresql+psycopg://trustmqtt:trustmqtt@postgres:5432/trustmqtt

# Worker config file (mounted from ./config/tmq.yaml — thresholds, weights,
# windows all live there now, not in env vars; see docs/SPEC.md §8)
TMQ_CONFIG=/app/config/tmq.yaml

# NVIDIA NIM (used by tmq_worker/llm.py for incident report generation;
# redact.py always strips identifying data before this key is ever used)
NVIDIA_API_KEY=your_nvapi_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# HMAC key used by redact.py to pseudonymize client_id/username before any
# data is sent to the LLM provider. Change this in any real deployment.
REDACTION_SECRET=dev-only-change-me

# Grafana
GRAFANA_ADMIN_PASSWORD=admin
