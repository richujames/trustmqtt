# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Database (SQLAlchemy URL)
DATABASE_URL=sqlite:///trustmqtt.db

# Mosquitto dynamic security control
MOSQUITTO_CONTROL_HOST=mosquitto
MOSQUITTO_CONTROL_PORT=1883

# Thresholds
DRIFT_THRESHOLD_MILD=0.5
DRIFT_THRESHOLD_MODERATE=0.75
DRIFT_THRESHOLD_SEVERE=0.9

# Shadow mode
SHADOW_MODE=true
